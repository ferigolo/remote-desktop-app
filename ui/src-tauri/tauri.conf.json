{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "remote-desktop-ui",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "remote-desktop-ui",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": [
      "binaries/core-engine"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}